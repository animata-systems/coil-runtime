            "type": "text",
            "value": "
  查询：",
          },
          {
            "name": "查询",
            "path": [],
            "type": "ref",
          },
          {
            "type": "text",
            "value": "
  查询历史：",
          },
          {
            "name": "查询历史",
            "path": [],
            "type": "ref",
          },
          {
            "type": "text",
            "value": "
  ",
          },
        ],
        "type": "template",
      },
      "goal": {
        "parts": [
          {
            "type": "text",
            "value": "
  准备一份有据可查的回答。
  ",
          },
        ],
        "type": "template",
      },
      "input": {
        "parts": [
          {
            "type": "text",
            "value": "
  研究用户的查询。将分析过程中
  通过流到达的所有数据纳入考量。
  ",
          },
        ],
        "type": "template",
      },
      "kind": "Op.Think",
      "name": "分析",
      "result": [
        {
          "depth": 0,
          "description": "最终回答",
          "name": "回答",
          "typeArgs": [],
          "typeId": "Typ.Text",
        },
        {
          "depth": 0,
          "description": "引用的参考资料",
          "name": "来源",
          "typeArgs": [],
          "typeId": "Typ.List",
        },
        {
          "depth": 1,
          "description": "来源链接",
          "name": "链接",
          "typeArgs": [],
          "typeId": "Typ.Text",
        },
        {
          "depth": 1,
          "description": "为什么相关",
          "name": "原因",
          "typeArgs": [],
          "typeId": "Typ.Text",
        },
        {
          "depth": 0,
          "description": "",
          "name": "置信度",
          "typeArgs": [
            "高",
            "中",
            "低",
          ],
          "typeId": "Typ.Choice",
        },
      ],
      "using": [],
      "via": null,
    },
    {
      "kind": "Comment",
      "text": "═══════════════════════════════════════",
    },
    {
      "kind": "Comment",
      "text": "2. 数据收集 —— 与思考并行。",
    },
    {
      "kind": "Comment",
      "text": "搜索和专家请求互不阻塞，",
    },
    {
      "kind": "Comment",
      "text": "也不阻塞 思考。",
    },
    {
      "kind": "Comment",
      "text": "═══════════════════════════════════════",
    },
    {
      "args": [
        {
          "key": "query",
          "value": {
            "name": "查询",
            "path": [],
            "type": "ref",
          },
        },
        {
          "key": "limit",
          "value": {
            "type": "number",
            "value": 10,
          },
        },
      ],
      "kind": "Op.Execute",
      "name": "已找到",
      "tool": {
        "name": "搜索",
      },
    },
    {
      "await": "any",
      "body": {
        "parts": [
          {
            "type": "text",
            "value": "
  需要关于此查询的专家意见：",
          },
          {
            "name": "查询",
            "path": [],
            "type": "ref",
          },
          {
            "type": "text",
            "value": "
  ",
          },
        ],
        "type": "template",
      },
      "for": [
        "专家",
      ],
      "kind": "Op.Send",
      "name": "意见",
      "replyTo": null,
      "timeout": {
        "unitId": "Dur.Minutes",
        "value": 10,
      },
      "to": {
        "segments": [
          {
            "kind": "literal",
            "value": "咨询",
          },
        ],
      },
    },
    {
      "kind": "Comment",
      "text": "═══════════════════════════════════════",
    },
    {
      "kind": "Comment",
      "text": "3. 在思考过程中补充输入。",
    },
    {
      "kind": "Comment",
      "text": "数据以任意顺序到达——",
    },
    {
      "kind": "Comment",
      "text": "每个结果立即注入 ~分析。",
    },
    {
      "kind": "Comment",
      "text": "LLM 无需重启即可纳入。",
    },
    {
      "kind": "Comment",
      "text": "═══════════════════════════════════════",
    },
    {
      "body": [
        {
          "kind": "Op.Wait",
          "mode": "any",
          "name": "数据",
          "on": [
            {
              "name": "已找到",
            },
            {
              "name": "意见",
            },
          ],
          "timeout": null,
        },
        {
          "body": {
            "parts": [
              {
                "type": "text",
                "value": "
    ",
              },
              {
                "name": "数据",
                "path": [],
                "type": "ref",
              },
              {
                "type": "text",
                "value": "
    ",
              },
            ],
            "type": "template",
          },
          "kind": "Op.Signal",
          "target": {
            "name": "分析",
          },
        },
      ],
      "kind": "Op.Repeat",
      "limit": 2,
      "until": null,
    },
    {
      "kind": "Comment",
      "text": "═══════════════════════════════════════",
    },
    {
      "kind": "Comment",
      "text": "4. 分析完成。",
    },
    {
      "kind": "Comment",
      "text": "结果综合了初始数据、",
    },
    {
      "kind": "Comment",
      "text": "搜索结果和专家意见。",
    },
    {
      "kind": "Comment",
      "text": "═══════════════════════════════════════",
    },
    {
      "kind": "Op.Wait",
      "mode": null,
      "name": null,
      "on": [
        {
          "name": "分析",
        },
      ],
      "timeout": null,
    },
    {
      "kind": "Comment",
      "text": "═══════════════════════════════════════",
    },
    {
      "kind": "Comment",
      "text": "5. 交付回答。",
    },
    {
      "kind": "Comment",
      "text": "═══════════════════════════════════════",
    },
    {
      "await": null,
      "body": {
        "parts": [
          {
            "type": "text",
            "value": "
  ",
          },
          {
            "name": "分析",
            "path": [
              "回答",
            ],
            "type": "ref",
          },
          {
            "type": "text",
            "value": "
  ",
          },
        ],
        "type": "template",
      },
      "for": [
        "作者",
      ],
      "kind": "Op.Send",
      "name": null,
      "replyTo": null,
      "timeout": null,
      "to": {
        "segments": [
          {
            "kind": "literal",
            "value": "结果",
          },
          {
            "kind": "dynamic",
            "name": "案例编号",
            "path": [],
          },
        ],
      },
    },
    {
      "kind": "Op.Exit",
    },
  ],
}
`;

