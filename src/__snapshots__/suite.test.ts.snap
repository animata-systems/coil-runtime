      ],
    },
    {
      "kind": "Op.Receive",
      "name": "message",
      "prompt": {
        "parts": [
          {
            "type": "text",
            "value": "
Опишите функцию для реализации.
",
          },
        ],
        "type": "template",
      },
    },
    {
      "body": {
        "parts": [
          {
            "type": "text",
            "value": "
Ты старший архитектор ПО. Планируй реализацию функций.
",
          },
        ],
        "type": "template",
      },
      "kind": "Op.Define",
      "name": "architect_role",
    },
    {
      "body": {
        "parts": [
          {
            "type": "text",
            "value": "
Ты эксперт по созданию новых файлов.
Следуй лучшим практикам и паттернам проекта.
",
          },
        ],
        "type": "template",
      },
      "kind": "Op.Define",
      "name": "worker_create_role",
    },
    {
      "body": {
        "parts": [
          {
            "type": "text",
            "value": "
Ты эксперт по модификации существующего кода.
Сохраняй консистентность и избегай регрессий.
",
          },
        ],
        "type": "template",
      },
      "kind": "Op.Define",
      "name": "worker_modify_role",
    },
    {
      "body": {
        "parts": [
          {
            "type": "text",
            "value": "
Ты эксперт по безопасному удалению кода.
Убедись, что нет сломанных зависимостей.
",
          },
        ],
        "type": "template",
      },
      "kind": "Op.Define",
      "name": "worker_delete_role",
    },
    {
      "kind": "Comment",
      "text": "═══════════════════════════════════════",
    },
    {
      "kind": "Comment",
      "text": "Планирование",
    },
    {
      "kind": "Comment",
      "text": "═══════════════════════════════════════",
    },
    {
      "as": [
        {
          "name": "architect_role",
          "path": [],
          "type": "ref",
        },
      ],
      "body": null,
      "context": null,
      "goal": {
        "parts": [
          {
            "type": "text",
            "value": "
  Проанализируй запрос на реализацию функции
  и создай план реализации.
  ",
          },
        ],
        "type": "template",
      },
      "input": {
        "parts": [
          {
            "type": "text",
            "value": "
  ",
          },
          {
            "name": "message",
            "path": [],
