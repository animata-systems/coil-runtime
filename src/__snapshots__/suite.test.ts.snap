          },
          {
            "type": "text",
            "value": "
  ",
          },
        ],
        "type": "template",
      },
      "for": [
        "инициатор",
      ],
      "kind": "Op.Send",
      "name": null,
      "replyTo": null,
      "timeout": null,
      "to": null,
    },
    {
      "kind": "Op.Exit",
    },
  ],
}
