                "value": 10,
              },
              "to": {
                "segments": [
                  {
                    "kind": "literal",
                    "value": "реализация",
                  },
                ],
              },
            },
          ],
          "condition": "$task.change_type == "modify"",
          "kind": "Op.If",
        },
        {
          "body": [
            {
              "await": "all",
              "body": {
                "parts": [
                  {
                    "type": "text",
                    "value": "
      Удали файл: ",
                  },
                  {
                    "name": "task",
                    "path": [
                      "file_path",
                    ],
                    "type": "ref",
                  },
                  {
                    "type": "text",
                    "value": "
      Назначение: ",
                  },
                  {
                    "name": "task",
                    "path": [
                      "purpose",
                    ],
                    "type": "ref",
                  },
                  {
                    "type": "text",
                    "value": "

      Контекст задачи: ",
                  },
                  {
                    "name": "message",
                    "path": [],
                    "type": "ref",
                  },
                  {
                    "type": "text",
                    "value": "
      ",
                  },
                ],
                "type": "template",
              },
              "for": [
                "удалятор",
              ],
              "kind": "Op.Send",
              "name": "work_result",
              "replyTo": null,
              "timeout": {
                "unitId": "Dur.Minutes",
                "value": 10,
              },
              "to": {
                "segments": [
                  {
                    "kind": "literal",
                    "value": "реализация",
                  },
                ],
              },
            },
          ],
          "condition": "$task.change_type == "delete"",
          "kind": "Op.If",
        },
        {
          "kind": "Op.Wait",
          "mode": null,
          "name": null,
          "on": [
            {
              "name": "work_result",
            },
          ],
          "timeout": null,
        },
      ],
      "element": {
        "name": "task",
        "path": [],
        "type": "ref",
      },
      "from": {
        "name": "parsed_plan",
        "path": [
          "files",
        ],
        "type": "ref",
      },
      "kind": "Op.Each",
    },
    {
      "kind": "Comment",
      "text": "═══════════════════════════════════════",
    },
    {
      "kind": "Comment",
      "text": "Ответ инициатору",
    },
    {
      "kind": "Comment",
      "text": "═══════════════════════════════════════",
    },
    {
      "await": null,
      "body": {
        "parts": [
          {
            "type": "text",
            "value": "
  Реализация завершена.
  План: ",
          },
          {
            "name": "parsed_plan",
            "path": [],
            "type": "ref",
          },
          {
            "type": "text",
            "value": "
  ",
          },
        ],
        "type": "template",
      },
      "for": [
        "инициатор",
      ],
      "kind": "Op.Send",
      "name": null,
      "replyTo": null,
      "timeout": null,
      "to": null,
    },
    {
      "kind": "Op.Exit",
    },
  ],
}
`;

