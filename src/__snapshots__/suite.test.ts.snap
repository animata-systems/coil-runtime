{
  "dialect": "ru-standard",
  "nodes": [
    {
      "kind": "Comment",
      "text": "@test valid",
    },
    {
      "kind": "Comment",
      "text": "@role pattern",
    },
    {
      "kind": "Comment",
      "text": "@status mixed",
    },
    {
      "kind": "Comment",
      "text": "@dialect ru-standard",
    },
    {
      "kind": "Comment",
      "text": "@covers Op.Think, Op.Wait, Op.If, Op.Send",
    },
    {
      "kind": "Comment",
      "text": "@description Цепочка промптов с оценкой",
    },
    {
      "kind": "Comment",
      "text": "",
    },
    {
      "kind": "Comment",
      "text": "═══════════════════════════════════════",
    },
    {
      "kind": "Comment",
      "text": "Паттерн: цепочка промптов с оценкой",
    },
    {
      "kind": "Comment",
      "text": "Маркетолог пишет текст, лингвист оценивает,",
    },
    {
      "kind": "Comment",
      "text": "если качество недостаточное — маркетолог переписывает.",
    },
    {
      "kind": "Comment",
      "text": "═══════════════════════════════════════",
    },
    {
      "kind": "Op.Actors",
      "names": [
        "инициатор",
      ],
    },
    {
      "kind": "Op.Receive",
      "name": "message",
      "prompt": {
        "parts": [
          {
            "type": "text",
            "value": "
Опишите продукт или услугу для маркетингового текста.
",
          },
        ],
        "type": "template",
      },
    },
    {
      "body": {
        "parts": [
          {
            "type": "text",
            "value": "
Ты маркетолог по контенту. Создавай тексты, которые продают:
посты, лендинги, рекламные объявления. Пиши ясно, убедительно
и ориентируясь на целевую аудиторию.
",
          },
        ],
        "type": "template",
      },
      "kind": "Op.Define",
      "name": "marketer_role",
    },
    {
      "body": {
        "parts": [
          {
            "type": "text",
            "value": "
Ты специалист по сравнительной лингвистике. Объясняй различия
между языками, переводами и языковыми конструкциями.
",
          },
        ],
        "type": "template",
      },
      "kind": "Op.Define",
      "name": "linguist_role",
    },
    {
      "kind": "Comment",
      "text": "═══════════════════════════════════════",
    },
    {
      "kind": "Comment",
      "text": "Первый черновик",
    },
    {
      "kind": "Comment",
      "text": "═══════════════════════════════════════",
    },
    {
      "as": [
        {
          "name": "marketer_role",
          "path": [],
          "type": "ref",
        },
      ],
      "body": null,
      "context": null,
      "goal": {
        "parts": [
          {
            "type": "text",
            "value": "
  Напишите убедительный маркетинговый текст.
  Сосредоточьтесь на преимуществах и эмоциональном воздействии.
  ",
          },
        ],
        "type": "template",
      },
      "input": {
        "parts": [
          {
            "type": "text",
            "value": "
  ",
          },
          {
            "name": "message",
            "path": [],
            "type": "ref",
          },
          {
            "type": "text",
            "value": "
  ",
          },
        ],
        "type": "template",
      },
      "kind": "Op.Think",
      "name": "draft",
      "result": [
        {
          "depth": 0,
          "description": "маркетинговый текст",
          "name": "text",
          "typeArgs": [],
          "typeId": "Typ.Text",
        },
      ],
      "using": [],
      "via": null,
    },
    {
      "kind": "Op.Wait",
      "mode": null,
      "name": null,
      "on": [
        {
          "name": "draft",
        },
      ],
      "timeout": null,
    },
    {
      "kind": "Comment",
      "text": "═══════════════════════════════════════",
    },
    {
      "kind": "Comment",
      "text": "Оценка качества",
    },
    {
      "kind": "Comment",
      "text": "═══════════════════════════════════════",
    },
    {
      "as": [
        {
          "name": "linguist_role",
          "path": [],
          "type": "ref",
        },
      ],
      "body": null,
      "context": null,
      "goal": {
        "parts": [
          {
            "type": "text",
            "value": "
  Оцените рекламный текст по критериям качества.
  ",
          },
        ],
        "type": "template",
      },
      "input": {
        "parts": [
          {
            "type": "text",
            "value": "
  ",
          },
          {
            "name": "draft",
            "path": [
              "text",
            ],
            "type": "ref",
          },
          {
            "type": "text",
            "value": "
  ",
          },
        ],
        "type": "template",
      },
      "kind": "Op.Think",
      "name": "quality_metrics",
      "result": [
        {
          "depth": 0,
          "description": "есть ли призыв к действию",
          "name": "has_call_to_action",
          "typeArgs": [],
          "typeId": "Typ.Flag",
        },
        {
          "depth": 0,
          "description": "эмоциональное воздействие от 1 до 10",
          "name": "emotional_appeal",
          "typeArgs": [],
          "typeId": "Typ.Number",
        },
        {
          "depth": 0,
          "description": "ясность текста от 1 до 10",
          "name": "clarity",
          "typeArgs": [],
          "typeId": "Typ.Number",
        },
      ],
      "using": [],
      "via": null,
    },
    {
      "kind": "Op.Wait",
      "mode": null,
      "name": null,
      "on": [
        {
          "name": "quality_metrics",
        },
      ],
      "timeout": null,
    },
    {
      "kind": "Comment",
      "text": "═══════════════════════════════════════",
    },
    {
      "kind": "Comment",
      "text": "Если качество недостаточное — улучшаем",
    },
    {
      "kind": "Comment",
      "text": "═══════════════════════════════════════",
    },
    {
      "body": {
        "type": "number",
        "value": 0,
      },
      "kind": "Op.Define",
      "name": "needs_improvement",
    },
    {
      "body": [
        {
          "body": {
            "type": "number",
            "value": 1,
          },
          "kind": "Op.Set",
          "target": {
            "name": "needs_improvement",
            "path": [],
            "type": "ref",
          },
        },
      ],
      "condition": "$quality_metrics.has_call_to_action == 0",
      "kind": "Op.If",
    },
    {
      "body": [
        {
          "body": {
            "type": "number",
            "value": 1,
          },
          "kind": "Op.Set",
          "target": {
            "name": "needs_improvement",
            "path": [],
            "type": "ref",
          },
        },
      ],
      "condition": "$quality_metrics.emotional_appeal < 7",
      "kind": "Op.If",
    },
    {
      "body": [
        {
