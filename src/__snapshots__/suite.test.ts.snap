    {
      "await": null,
      "body": {
        "parts": [
          {
            "type": "text",
            "value": "
  ",
          },
          {
            "name": "analysis",
            "path": [
              "answer",
            ],
            "type": "ref",
          },
          {
            "type": "text",
            "value": "
  ",
