exports[`dialect showcases > fr-standard 1`] = `
{
  "dialect": "fr-standard",
  "nodes": [
    {
      "kind": "Comment",
      "text": "═══════════════════════════════════════",
    },
    {
      "kind": "Comment",
      "text": "Environnement",
    },
    {
      "kind": "Comment",
      "text": "═══════════════════════════════════════",
    },
    {
      "kind": "Op.Actors",
      "names": [
        "expert",
        "auteur",
      ],
    },
    {
      "kind": "Op.Tools",
      "names": [
        "recherche",
      ],
    },
    {
      "kind": "Comment",
      "text": "═══════════════════════════════════════",
    },
    {
      "kind": "Comment",
      "text": "Rôles — profils d'expertise pour le LLM.",
    },
    {
      "kind": "Comment",
      "text": "Quelles connaissances et quelle approche",
    },
    {
      "kind": "Comment",
      "text": "le LLM doit adopter pour la tâche.",
    },
    {
      "kind": "Comment",
      "text": "═══════════════════════════════════════",
    },
    {
      "body": {
        "parts": [
          {
            "type": "text",
            "value": "
Tu es un analyste-chercheur.
Tu travailles avec des requêtes non structurées.
Tu cherches toujours les sources primaires et indiques
ton degré de confiance dans tes conclusions.
Tu évites les spéculations.
Si les données sont insuffisantes — tu le dis clairement.
",
          },
        ],
        "type": "template",
      },
      "kind": "Op.Define",
      "name": "compétence_recherche",
    },
    {
      "body": {
        "parts": [
          {
            "type": "text",
            "value": "
Tu maîtrises l'analyse produit.
Tu connais les métriques de rétention, d'activation et de churn.
Tu sais lire les funnels et les rapports de cohorte.
Dans ton analyse, tu distingues toujours
la corrélation de la causalité.
",
          },
        ],
        "type": "template",
      },
      "kind": "Op.Define",
      "name": "expertise_domaine",
    },
    {
      "kind": "Comment",
      "text": "═══════════════════════════════════════",
    },
    {
      "kind": "Comment",
      "text": "Données d'entrée — l'environnement doit fournir",
    },
    {
      "kind": "Comment",
      "text": "ces valeurs avant que le protocole ne continue.",
    },
    {
      "kind": "Comment",
      "text": "═══════════════════════════════════════",
    },
    {
      "kind": "Op.Receive",
      "name": "requête",
      "prompt": {
        "parts": [
          {
            "type": "text",
            "value": "
Requête utilisateur pour la recherche.
",
          },
        ],
        "type": "template",
      },
      "timeout": null,
    },
    {
      "kind": "Op.Receive",
      "name": "historique",
      "prompt": {
        "parts": [
          {
            "type": "text",
            "value": "
Historique des requêtes précédentes sur ce sujet.
",
          },
        ],
        "type": "template",
      },
      "timeout": null,
    },
    {
      "kind": "Op.Receive",
      "name": "dossier_id",
      "prompt": {
        "parts": [
          {
            "type": "text",
            "value": "
Identifiant du dossier en cours.
",
          },
        ],
        "type": "template",
      },
      "timeout": null,
    },
    {
      "kind": "Comment",
      "text": "═══════════════════════════════════════",
    },
    {
      "kind": "Comment",
      "text": "1. Énoncé de la tâche — structuré comme un",
    },
    {
      "kind": "Comment",
      "text": "problème de mathématiques :",
    },
    {
      "kind": "Comment",
      "text": "COMME    — rôle / profil d'expert",
    },
    {
      "kind": "Comment",
      "text": "OBJECTIF — ce que l'on veut atteindre",
    },
    {
      "kind": "Comment",
      "text": "ENTRÉE   — données du problème",
    },
    {
      "kind": "Comment",
      "text": "CONTEXTE — informations de fond",
    },
    {
      "kind": "Comment",
      "text": "RÉSULTAT — ce qu'il faut déterminer",
    },
    {
      "kind": "Comment",
      "text": "",
    },
    {
      "kind": "Comment",
      "text": "PENSE s'exécute en arrière-plan. Crée une",
    },
    {
      "kind": "Comment",
      "text": "promesse de résultat ?analyse et un flux",
    },
    {
      "kind": "Comment",
      "text": "en direct ~analyse. Les entrées peuvent être",
    },
    {
      "kind": "Comment",
      "text": "complétées pendant la réflexion via SIGNAL.",
    },
    {
      "kind": "Comment",
      "text": "═══════════════════════════════════════",
    },
    {
      "as": [
        {
          "name": "compétence_recherche",
          "path": [],
          "type": "ref",
        },
        {
          "name": "expertise_domaine",
          "path": [],
          "type": "ref",
        },
      ],
      "body": null,
      "context": {
        "parts": [
          {
            "type": "text",
            "value": "
  Requête : ",
          },
          {
            "name": "requête",
            "path": [],
            "type": "ref",
          },
          {
            "type": "text",
            "value": "
  Historique : ",
          },
          {
            "name": "historique",
            "path": [],
            "type": "ref",
          },
          {
            "type": "text",
            "value": "
  ",
          },
        ],
        "type": "template",
      },
      "goal": {
        "parts": [
          {
            "type": "text",
            "value": "
  Préparer une réponse fondée avec des sources.
  ",
          },
        ],
        "type": "template",
      },
      "input": {
        "parts": [
          {
            "type": "text",
            "value": "
  Recherche la requête de l'utilisateur. Intègre
  toutes les données qui arrivent via le flux
  pendant l'analyse.
  ",
          },
        ],
        "type": "template",
      },
      "kind": "Op.Think",
      "name": "analyse",
      "result": [
        {
          "depth": 0,
          "description": "réponse finale",
          "name": "réponse",
          "typeArgs": [],
          "typeId": "Typ.Text",
        },
        {
          "depth": 0,
          "description": "références citées",
          "name": "sources",
          "typeArgs": [],
          "typeId": "Typ.List",
        },
        {
          "depth": 1,
          "description": "lien de la source",
          "name": "ref",
          "typeArgs": [],
          "typeId": "Typ.Text",
        },
        {
          "depth": 1,
          "description": "en quoi c'est pertinent",
          "name": "pourquoi",
          "typeArgs": [],
          "typeId": "Typ.Text",
        },
        {
          "depth": 0,
          "description": "",
          "name": "confiance",
          "typeArgs": [
            "haute",
            "moyenne",
            "faible",
          ],
          "typeId": "Typ.Choice",
        },
      ],
      "using": [],
      "via": null,
    },
    {
      "kind": "Comment",
      "text": "═══════════════════════════════════════",
    },
    {
      "kind": "Comment",
      "text": "2. Collecte de données — en parallèle avec",
    },
    {
      "kind": "Comment",
      "text": "la réflexion. La recherche et la demande",
    },
    {
      "kind": "Comment",
      "text": "d'avis ne bloquent ni l'une l'autre ni PENSE.",
    },
    {
      "kind": "Comment",
      "text": "═══════════════════════════════════════",
    },
    {
      "args": [
        {
          "key": "query",
          "value": {
            "name": "requête",
            "path": [],
            "type": "ref",
          },
        },
        {
          "key": "limit",
          "value": {
            "type": "number",
            "value": 10,
          },
        },
      ],
      "kind": "Op.Execute",
      "name": "trouvé",
      "tool": {
        "name": "recherche",
      },
    },
    {
      "await": "any",
      "body": {
        "parts": [
          {
            "type": "text",
            "value": "
  Besoin d'un avis d'expert sur la requête : ",
          },
          {
            "name": "requête",
            "path": [],
            "type": "ref",
          },
          {
            "type": "text",
            "value": "
  ",
          },
        ],
        "type": "template",
      },
      "for": [
        "expert",
      ],
      "kind": "Op.Send",
      "name": "avis",
      "replyTo": null,
      "timeout": {
        "unitId": "Dur.Minutes",
        "value": 10,
      },
      "to": {
        "segments": [
          {
            "kind": "literal",
            "value": "consultations",
          },
        ],
      },
    },
    {
      "kind": "Comment",
      "text": "═══════════════════════════════════════",
    },
    {
      "kind": "Comment",
      "text": "3. Compléter les entrées pendant la réflexion.",
    },
    {
      "kind": "Comment",
      "text": "Les données arrivent dans un ordre quelconque —",
    },
    {
      "kind": "Comment",
      "text": "chaque résultat est injecté dans ~analyse",
    },
    {
      "kind": "Comment",
      "text": "immédiatement. Le LLM l'intègre sans redémarrer.",
    },
    {
      "kind": "Comment",
      "text": "═══════════════════════════════════════",
    },
    {
      "body": [
        {
          "kind": "Op.Wait",
          "mode": "any",
          "name": "données",
          "on": [
            {
              "name": "trouvé",
            },
            {
              "name": "avis",
            },
          ],
          "timeout": null,
        },
        {
          "body": {
            "parts": [
              {
                "type": "text",
                "value": "
    ",
              },
              {
                "name": "données",
                "path": [],
                "type": "ref",
              },
              {
                "type": "text",
                "value": "
    ",
              },
            ],
            "type": "template",
          },
          "kind": "Op.Signal",
          "target": {
            "name": "analyse",
          },
        },
      ],
      "kind": "Op.Repeat",
      "limit": 2,
      "until": null,
    },
    {
      "kind": "Comment",
      "text": "═══════════════════════════════════════",
    },
    {
      "kind": "Comment",
      "text": "4. L'analyse est terminée.",
    },
    {
      "kind": "Comment",
      "text": "Le résultat intègre les données initiales,",
    },
    {
      "kind": "Comment",
      "text": "les résultats de recherche et l'avis d'expert.",
    },
    {
      "kind": "Comment",
      "text": "═══════════════════════════════════════",
    },
    {
      "kind": "Op.Wait",
      "mode": null,
      "name": null,
      "on": [
        {
          "name": "analyse",
        },
      ],
      "timeout": null,
    },
    {
      "kind": "Comment",
      "text": "═══════════════════════════════════════",
    },
    {
      "kind": "Comment",
      "text": "5. Transmettre la réponse.",
    },
    {
      "kind": "Comment",
      "text": "═══════════════════════════════════════",
    },
    {
      "await": null,
      "body": {
        "parts": [
          {
            "type": "text",
            "value": "
  ",
          },
          {
            "name": "analyse",
            "path": [
              "réponse",
            ],
            "type": "ref",
          },
          {
            "type": "text",
            "value": "
  ",
          },
        ],
        "type": "template",
      },
      "for": [
        "auteur",
      ],
      "kind": "Op.Send",
      "name": null,
      "replyTo": null,
      "timeout": null,
      "to": {
        "segments": [
          {
            "kind": "literal",
            "value": "résultats",
          },
          {
            "kind": "dynamic",
            "name": "dossier_id",
            "path": [],
          },
        ],
      },
    },
    {
      "kind": "Op.Exit",
    },
  ],
}
`;

