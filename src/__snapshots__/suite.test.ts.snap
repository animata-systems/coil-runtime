exports[`dialect showcases > de-standard 1`] = `
{
  "dialect": "de-standard",
  "nodes": [
    {
      "kind": "Comment",
      "text": "═══════════════════════════════════════",
    },
    {
      "kind": "Comment",
      "text": "Umgebung",
    },
    {
      "kind": "Comment",
      "text": "═══════════════════════════════════════",
    },
    {
      "kind": "Op.Actors",
      "names": [
        "experte",
        "autor",
      ],
    },
    {
      "kind": "Op.Tools",
      "names": [
        "suche",
      ],
    },
    {
      "kind": "Comment",
      "text": "═══════════════════════════════════════",
    },
    {
      "kind": "Comment",
      "text": "Rollen — Expertenprofile für das LLM.",
    },
    {
      "kind": "Comment",
      "text": "Welches Wissen und welchen Ansatz",
    },
    {
      "kind": "Comment",
      "text": "das LLM bei der Aufgabe einsetzen soll.",
    },
    {
      "kind": "Comment",
      "text": "═══════════════════════════════════════",
    },
    {
      "body": {
        "parts": [
          {
            "type": "text",
            "value": "
Du bist ein Research-Analyst.
Du arbeitest mit unstrukturierten Anfragen.
Du suchst immer nach Primärquellen und gibst
den Grad deiner Sicherheit bei Schlussfolgerungen an.
Du vermeidest Spekulationen.
Wenn die Datenlage unzureichend ist — sagst du das direkt.
",
          },
        ],
        "type": "template",
      },
      "kind": "Op.Define",
      "name": "recherche_skill",
    },
    {
      "body": {
        "parts": [
          {
            "type": "text",
            "value": "
Du kennst dich mit Produktanalyse aus.
Du verstehst Retention, Activation und Churn.
Du kannst Funnels und Kohortenberichte lesen.
Bei der Analyse unterscheidest du immer zwischen
Korrelation und Kausalität.
",
          },
        ],
        "type": "template",
      },
      "kind": "Op.Define",
      "name": "fachkompetenz",
    },
    {
      "kind": "Comment",
      "text": "═══════════════════════════════════════",
    },
    {
      "kind": "Comment",
      "text": "Eingabedaten — die Umgebung muss diese Werte",
    },
    {
      "kind": "Comment",
      "text": "liefern, bevor das Protokoll fortfährt.",
    },
    {
      "kind": "Comment",
      "text": "═══════════════════════════════════════",
    },
    {
      "kind": "Op.Receive",
      "name": "anfrage",
      "prompt": {
        "parts": [
          {
            "type": "text",
            "value": "
Nutzeranfrage zur Recherche.
",
          },
        ],
        "type": "template",
      },
      "timeout": null,
    },
    {
      "kind": "Op.Receive",
      "name": "anfragenverlauf",
      "prompt": {
        "parts": [
          {
            "type": "text",
            "value": "
Verlauf früherer Anfragen zu diesem Thema.
",
          },
        ],
        "type": "template",
      },
      "timeout": null,
    },
    {
      "kind": "Op.Receive",
      "name": "fall_id",
      "prompt": {
        "parts": [
          {
            "type": "text",
            "value": "
Kennung des aktuellen Falls.
",
          },
        ],
        "type": "template",
      },
      "timeout": null,
    },
    {
      "kind": "Comment",
      "text": "═══════════════════════════════════════",
    },
    {
      "kind": "Comment",
      "text": "1. Aufgabenstellung — wie ein mathematisches",
    },
    {
      "kind": "Comment",
      "text": "Problem strukturiert:",
    },
    {
      "kind": "Comment",
      "text": "ALS      — Rolle / Expertenprofil",
    },
    {
      "kind": "Comment",
      "text": "ZIEL     — was erreicht werden soll",
    },
    {
      "kind": "Comment",
      "text": "EINGABE  — Aufgabendaten",
    },
    {
      "kind": "Comment",
      "text": "KONTEXT  — Hintergrundinformationen",
    },
    {
      "kind": "Comment",
      "text": "ERGEBNIS — was bestimmt werden soll",
    },
    {
      "kind": "Comment",
      "text": "",
    },
    {
      "kind": "Comment",
      "text": "DENKE läuft im Hintergrund. Erzeugt ein",
    },
    {
      "kind": "Comment",
      "text": "Ergebnisversprechen ?analyse und einen",
    },
    {
      "kind": "Comment",
      "text": "Live-Strom ~analyse. Eingaben können",
    },
    {
      "kind": "Comment",
      "text": "während des Denkens über SIGNAL ergänzt werden.",
    },
    {
      "kind": "Comment",
      "text": "═══════════════════════════════════════",
    },
    {
      "as": [
        {
          "name": "recherche_skill",
          "path": [],
          "type": "ref",
        },
        {
          "name": "fachkompetenz",
          "path": [],
          "type": "ref",
        },
      ],
      "body": null,
      "context": {
        "parts": [
          {
            "type": "text",
            "value": "
  Anfrage: ",
          },
          {
            "name": "anfrage",
            "path": [],
            "type": "ref",
          },
          {
            "type": "text",
            "value": "
  Anfragenverlauf: ",
          },
          {
            "name": "anfragenverlauf",
            "path": [],
            "type": "ref",
          },
          {
            "type": "text",
            "value": "
  ",
          },
        ],
        "type": "template",
      },
      "goal": {
        "parts": [
          {
            "type": "text",
            "value": "
  Eine fundierte Antwort mit Quellen vorbereiten.
  ",
          },
        ],
        "type": "template",
      },
      "input": {
        "parts": [
          {
            "type": "text",
            "value": "
  Recherchiere die Nutzeranfrage. Berücksichtige
  alle Daten, die während der Analyse über den
  Strom eintreffen.
  ",
          },
        ],
        "type": "template",
      },
      "kind": "Op.Think",
      "name": "analyse",
      "result": [
        {
          "depth": 0,
          "description": "endgültige Antwort",
          "name": "antwort",
          "typeArgs": [],
          "typeId": "Typ.Text",
        },
        {
          "depth": 0,
          "description": "herangezogene Referenzen",
          "name": "quellen",
          "typeArgs": [],
          "typeId": "Typ.List",
        },
        {
          "depth": 1,
          "description": "Quellenlink",
          "name": "ref",
          "typeArgs": [],
          "typeId": "Typ.Text",
        },
        {
          "depth": 1,
          "description": "warum relevant",
          "name": "warum",
          "typeArgs": [],
          "typeId": "Typ.Text",
        },
        {
          "depth": 0,
          "description": "",
          "name": "sicherheit",
          "typeArgs": [
            "hoch",
            "mittel",
            "niedrig",
          ],
          "typeId": "Typ.Choice",
        },
      ],
      "using": [],
      "via": null,
    },
    {
      "kind": "Comment",
      "text": "═══════════════════════════════════════",
    },
    {
      "kind": "Comment",
      "text": "2. Datenerhebung — parallel zum Denkprozess.",
    },
    {
      "kind": "Comment",
      "text": "Suche und Expertenanfrage blockieren",
    },
    {
      "kind": "Comment",
      "text": "weder einander noch DENKE.",
    },
    {
      "kind": "Comment",
      "text": "═══════════════════════════════════════",
    },
    {
      "args": [
        {
          "key": "query",
          "value": {
            "name": "anfrage",
            "path": [],
            "type": "ref",
          },
        },
        {
          "key": "limit",
          "value": {
            "type": "number",
            "value": 10,
          },
        },
      ],
      "kind": "Op.Execute",
      "name": "gefunden",
      "tool": {
        "name": "suche",
      },
    },
    {
      "await": "any",
      "body": {
        "parts": [
          {
            "type": "text",
            "value": "
  Brauche Expertenmeinung zur Anfrage: ",
          },
          {
            "name": "anfrage",
            "path": [],
            "type": "ref",
          },
          {
            "type": "text",
            "value": "
  ",
          },
        ],
        "type": "template",
      },
      "for": [
        "experte",
      ],
      "kind": "Op.Send",
      "name": "meinung",
      "replyTo": null,
      "timeout": {
        "unitId": "Dur.Minutes",
        "value": 10,
      },
      "to": {
        "segments": [
          {
            "kind": "literal",
            "value": "beratung",
          },
        ],
      },
    },
    {
      "kind": "Comment",
      "text": "═══════════════════════════════════════",
    },
    {
      "kind": "Comment",
      "text": "3. Eingaben während des Denkens ergänzen.",
    },
    {
      "kind": "Comment",
      "text": "Daten treffen in beliebiger Reihenfolge ein —",
