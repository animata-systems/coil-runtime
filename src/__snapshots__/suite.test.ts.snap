exports[`dialect showcases > en-standard 1`] = `
{
  "dialect": "en-standard",
  "nodes": [
    {
      "kind": "Comment",
      "text": "═══════════════════════════════════════",
    },
    {
      "kind": "Comment",
      "text": "Environment",
    },
    {
      "kind": "Comment",
      "text": "═══════════════════════════════════════",
    },
    {
      "kind": "Op.Actors",
      "names": [
        "expert",
        "author",
      ],
    },
    {
      "kind": "Op.Tools",
      "names": [
        "search",
      ],
    },
    {
      "kind": "Comment",
      "text": "═══════════════════════════════════════",
    },
    {
      "kind": "Comment",
      "text": "Roles — expert profiles for LLM.",
    },
    {
      "kind": "Comment",
      "text": "Define the knowledge and approach",
    },
    {
      "kind": "Comment",
      "text": "the LLM should adopt for a task.",
    },
    {
      "kind": "Comment",
      "text": "═══════════════════════════════════════",
    },
    {
      "body": {
        "parts": [
          {
            "type": "text",
            "value": "
You are a research analyst.
You work with unstructured queries.
You always look for primary sources and indicate
your confidence level in conclusions. You avoid speculation.
If the data is insufficient — you say so directly.
",
          },
        ],
        "type": "template",
      },
      "kind": "Op.Define",
      "name": "research_skill",
    },
    {
      "body": {
        "parts": [
          {
            "type": "text",
            "value": "
You are well-versed in product analytics.
You know retention, activation, and churn metrics.
You can read funnels and cohort reports.
When analyzing, you always distinguish between
correlation and causation.
",
          },
        ],
        "type": "template",
      },
      "kind": "Op.Define",
      "name": "domain_expertise",
    },
    {
      "kind": "Comment",
      "text": "═══════════════════════════════════════",
    },
    {
      "kind": "Comment",
      "text": "Input data — the environment must provide",
    },
    {
      "kind": "Comment",
      "text": "values before the protocol continues.",
    },
    {
      "kind": "Comment",
      "text": "═══════════════════════════════════════",
    },
    {
      "kind": "Op.Receive",
      "name": "query",
      "prompt": {
        "parts": [
          {
            "type": "text",
            "value": "
User query for research.
",
          },
        ],
        "type": "template",
      },
      "timeout": null,
    },
    {
      "kind": "Op.Receive",
      "name": "request_history",
      "prompt": {
        "parts": [
          {
            "type": "text",
            "value": "
History of previous requests on this topic.
",
          },
        ],
        "type": "template",
      },
      "timeout": null,
    },
    {
      "kind": "Op.Receive",
      "name": "case_id",
      "prompt": {
        "parts": [
          {
            "type": "text",
            "value": "
Current case identifier.
",
          },
        ],
        "type": "template",
      },
      "timeout": null,
    },
    {
      "kind": "Comment",
      "text": "═══════════════════════════════════════",
    },
    {
      "kind": "Comment",
      "text": "1. Task definition — structured like a math problem:",
    },
    {
      "kind": "Comment",
      "text": "AS      — role / expert profile",
    },
    {
      "kind": "Comment",
      "text": "GOAL    — objective",
    },
    {
      "kind": "Comment",
      "text": "INPUT   — problem data",
    },
    {
      "kind": "Comment",
      "text": "CONTEXT — background info",
    },
    {
      "kind": "Comment",
      "text": "RESULT  — what to determine",
    },
    {
      "kind": "Comment",
      "text": "",
    },
    {
      "kind": "Comment",
      "text": "THINK runs in the background. Creates a result",
    },
    {
      "kind": "Comment",
      "text": "promise ?analysis and a live stream ~analysis.",
    },
    {
      "kind": "Comment",
      "text": "Input can be supplemented while thinking",
    },
    {
      "kind": "Comment",
      "text": "is in progress via SIGNAL.",
    },
    {
      "kind": "Comment",
      "text": "═══════════════════════════════════════",
    },
    {
      "as": [
        {
          "name": "research_skill",
          "path": [],
          "type": "ref",
        },
        {
          "name": "domain_expertise",
          "path": [],
          "type": "ref",
        },
      ],
      "body": null,
      "context": {
        "parts": [
          {
            "type": "text",
            "value": "
  Query: ",
          },
          {
            "name": "query",
            "path": [],
            "type": "ref",
          },
          {
            "type": "text",
            "value": "
  Request history: ",
          },
          {
            "name": "request_history",
            "path": [],
            "type": "ref",
          },
          {
            "type": "text",
            "value": "
  ",
          },
        ],
        "type": "template",
      },
      "goal": {
        "parts": [
          {
            "type": "text",
            "value": "
  Prepare a well-grounded answer with sources.
  ",
          },
        ],
        "type": "template",
      },
      "input": {
        "parts": [
          {
            "type": "text",
            "value": "
  Research the user's query. Incorporate any data
  that arrives via the stream during analysis.
  ",
          },
        ],
        "type": "template",
      },
      "kind": "Op.Think",
      "name": "analysis",
      "result": [
        {
          "depth": 0,
          "description": "final answer",
          "name": "answer",
          "typeArgs": [],
          "typeId": "Typ.Text",
        },
        {
          "depth": 0,
          "description": "references cited",
          "name": "sources",
          "typeArgs": [],
          "typeId": "Typ.List",
        },
        {
          "depth": 1,
          "description": "reference link",
          "name": "ref",
          "typeArgs": [],
          "typeId": "Typ.Text",
        },
        {
          "depth": 1,
          "description": "why it is relevant",
          "name": "why",
          "typeArgs": [],
          "typeId": "Typ.Text",
        },
        {
          "depth": 0,
          "description": "",
          "name": "confidence",
          "typeArgs": [
            "high",
            "medium",
            "low",
          ],
          "typeId": "Typ.Choice",
        },
      ],
      "using": [],
      "via": null,
    },
    {
      "kind": "Comment",
      "text": "═══════════════════════════════════════",
    },
    {
      "kind": "Comment",
      "text": "2. Data collection — parallel to reasoning.",
    },
    {
      "kind": "Comment",
      "text": "Search and expert request block",
    },
    {
      "kind": "Comment",
      "text": "neither each other nor THINK.",
    },
    {
      "kind": "Comment",
      "text": "═══════════════════════════════════════",
    },
    {
      "args": [
        {
          "key": "query",
          "value": {
            "name": "query",
            "path": [],
            "type": "ref",
          },
        },
        {
          "key": "limit",
          "value": {
            "type": "number",
            "value": 10,
          },
        },
      ],
      "kind": "Op.Execute",
      "name": "found",
      "tool": {
        "name": "search",
      },
    },
    {
      "await": "any",
      "body": {
        "parts": [
          {
            "type": "text",
            "value": "
  Need expertise on query: ",
          },
          {
            "name": "query",
            "path": [],
            "type": "ref",
          },
          {
            "type": "text",
            "value": "
  ",
          },
        ],
        "type": "template",
      },
      "for": [
        "expert",
      ],
      "kind": "Op.Send",
      "name": "opinion",
      "replyTo": null,
      "timeout": {
        "unitId": "Dur.Minutes",
        "value": 10,
      },
      "to": {
        "segments": [
          {
            "kind": "literal",
            "value": "consultations",
          },
        ],
      },
    },
    {
      "kind": "Comment",
      "text": "═══════════════════════════════════════",
    },
    {
      "kind": "Comment",
      "text": "3. Supplementing input while thinking.",
    },
    {
      "kind": "Comment",
      "text": "Data arrives in arbitrary order —",
    },
    {
      "kind": "Comment",
      "text": "each result is fed into ~analysis immediately.",
    },
    {
      "kind": "Comment",
      "text": "The LLM incorporates it without restarting.",
    },
    {
      "kind": "Comment",
      "text": "═══════════════════════════════════════",
    },
    {
      "body": [
        {
          "kind": "Op.Wait",
          "mode": "any",
          "name": "data",
