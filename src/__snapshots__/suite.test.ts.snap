exports[`executable examples > patterns/evaluator-optimizer.coil 1`] = `
{
  "dialect": "ru-standard",
  "nodes": [
    {
      "kind": "Comment",
      "text": "@test valid",
    },
    {
      "kind": "Comment",
      "text": "@role pattern",
    },
    {
      "kind": "Comment",
      "text": "@status mixed",
    },
    {
      "kind": "Comment",
      "text": "@dialect ru-standard",
    },
    {
      "kind": "Comment",
      "text": "@covers Op.Think, Op.Repeat, Op.If, Op.Set",
    },
    {
      "kind": "Comment",
      "text": "@description Итеративная оценка и улучшение",
    },
    {
      "kind": "Comment",
      "text": "",
    },
    {
      "kind": "Comment",
      "text": "═══════════════════════════════════════",
    },
    {
      "kind": "Comment",
      "text": "Паттерн: итеративная оценка и улучшение",
    },
    {
      "kind": "Comment",
      "text": "Переводчик делает перевод, оценщик проверяет,",
    },
    {
      "kind": "Comment",
      "text": "цикл повторяется до достижения качества.",
    },
    {
      "kind": "Comment",
      "text": "═══════════════════════════════════════",
    },
    {
      "kind": "Op.Actors",
      "names": [
        "инициатор",
      ],
    },
    {
      "kind": "Op.Receive",
      "name": "message",
      "prompt": {
        "parts": [
          {
            "type": "text",
            "value": "
Введите текст для перевода.
",
          },
        ],
        "type": "template",
      },
    },
    {
      "kind": "Op.Receive",
      "name": "target_language",
      "prompt": {
        "parts": [
          {
            "type": "text",
            "value": "
На какой язык перевести?
",
          },
        ],
        "type": "template",
      },
    },
    {
      "body": {
        "parts": [
          {
            "type": "text",
            "value": "
Ты эксперт по литературному переводу.
",
          },
        ],
        "type": "template",
      },
      "kind": "Op.Define",
      "name": "translator_role",
    },
    {
      "body": {
        "parts": [
          {
            "type": "text",
            "value": "
Ты эксперт по оценке литературных переводов.
",
          },
        ],
        "type": "template",
      },
      "kind": "Op.Define",
      "name": "evaluator_role",
    },
    {
      "kind": "Comment",
      "text": "═══════════════════════════════════════",
    },
    {
      "kind": "Comment",
      "text": "Первый перевод",
    },
    {
      "kind": "Comment",
      "text": "═══════════════════════════════════════",
    },
    {
      "as": [
        {
          "name": "translator_role",
          "path": [],
          "type": "ref",
        },
      ],
      "body": null,
      "context": null,
      "goal": {
        "parts": [
          {
            "type": "text",
            "value": "
  Переведите текст на ",
          },
          {
            "name": "target_language",
            "path": [],
            "type": "ref",
          },
          {
            "type": "text",
            "value": ",
  сохраняя тон и культурные нюансы.
  ",
          },
        ],
        "type": "template",
      },
      "input": {
        "parts": [
          {
            "type": "text",
            "value": "
  ",
          },
          {
            "name": "message",
            "path": [],
            "type": "ref",
          },
          {
            "type": "text",
            "value": "
  ",
          },
        ],
        "type": "template",
      },
      "kind": "Op.Think",
      "name": "initial_translation",
      "result": [
        {
          "depth": 0,
          "description": "перевод",
          "name": "text",
          "typeArgs": [],
          "typeId": "Typ.Text",
        },
      ],
      "using": [],
      "via": null,
    },
    {
      "kind": "Op.Wait",
      "mode": null,
      "name": null,
      "on": [
        {
          "name": "initial_translation",
        },
      ],
      "timeout": null,
    },
    {
      "body": {
        "name": "initial_translation",
        "path": [
          "text",
        ],
        "type": "ref",
      },
      "kind": "Op.Define",
      "name": "current_translation",
    },
    {
      "body": {
        "type": "number",
        "value": 0,
      },
      "kind": "Op.Define",
      "name": "done",
    },
    {
      "kind": "Comment",
      "text": "═══════════════════════════════════════",
    },
    {
      "kind": "Comment",
      "text": "Цикл оценки и улучшения",
    },
    {
      "kind": "Comment",
      "text": "═══════════════════════════════════════",
    },
    {
      "body": [
        {
          "as": [
            {
              "name": "evaluator_role",
              "path": [],
              "type": "ref",
            },
          ],
          "body": null,
          "context": null,
          "goal": {
            "parts": [
              {
                "type": "text",
                "value": "
    Оцените качество перевода.
    ",
              },
            ],
            "type": "template",
          },
          "input": {
            "parts": [
              {
                "type": "text",
                "value": "
    Оригинал: ",
              },
              {
                "name": "message",
                "path": [],
                "type": "ref",
              },
              {
                "type": "text",
                "value": "
    Перевод: ",
              },
              {
                "name": "current_translation",
                "path": [],
                "type": "ref",
              },
              {
                "type": "text",
                "value": "
    ",
              },
            ],
            "type": "template",
          },
          "kind": "Op.Think",
          "name": "evaluation",
          "result": [
            {
              "depth": 0,
              "description": "общее качество от 1 до 10",
              "name": "quality_score",
              "typeArgs": [],
              "typeId": "Typ.Number",
            },
            {
              "depth": 0,
              "description": "сохранён ли тон оригинала",
              "name": "preserves_tone",
              "typeArgs": [],
              "typeId": "Typ.Flag",
            },
            {
              "depth": 0,
              "description": "сохранены ли нюансы",
              "name": "preserves_nuance",
              "typeArgs": [],
              "typeId": "Typ.Flag",
            },
            {
              "depth": 0,
              "description": "культурная точность",
              "name": "culturally_accurate",
              "typeArgs": [],
              "typeId": "Typ.Flag",
            },
            {
              "depth": 0,
              "description": "конкретные проблемы",
              "name": "specific_issues",
              "typeArgs": [],
              "typeId": "Typ.Text",
            },
            {
              "depth": 0,
              "description": "предложения по улучшению",
              "name": "improvement_suggestions",
              "typeArgs": [],
              "typeId": "Typ.Text",
            },
          ],
          "using": [],
          "via": null,
        },
        {
          "kind": "Op.Wait",
          "mode": null,
          "name": null,
          "on": [
            {
              "name": "evaluation",
            },
          ],
          "timeout": null,
        },
        {
          "body": [
            {
              "body": {
                "type": "number",
                "value": 1,
              },
              "kind": "Op.Set",
              "target": {
                "name": "done",
                "path": [],
                "type": "ref",
              },
            },
          ],
          "condition": "$evaluation.quality_score >= 8",
          "kind": "Op.If",
        },
        {
          "body": [
            {
              "as": [
                {
