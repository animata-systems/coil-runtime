          "kind": "Op.Wait",
          "mode": "any",
          "name": "daten",
          "on": [
            {
              "name": "gefunden",
            },
            {
              "name": "meinung",
            },
          ],
          "timeout": null,
        },
        {
          "body": {
            "parts": [
              {
                "type": "text",
                "value": "
    ",
              },
              {
                "name": "daten",
                "path": [],
                "type": "ref",
              },
              {
                "type": "text",
                "value": "
    ",
              },
            ],
            "type": "template",
          },
          "kind": "Op.Signal",
          "target": {
            "name": "analyse",
          },
        },
      ],
      "kind": "Op.Repeat",
      "limit": 2,
      "until": null,
    },
    {
      "kind": "Comment",
      "text": "═══════════════════════════════════════",
    },
    {
      "kind": "Comment",
      "text": "4. Die Analyse ist abgeschlossen.",
    },
    {
      "kind": "Comment",
      "text": "Das Ergebnis berücksichtigt Ausgangsdaten,",
    },
    {
      "kind": "Comment",
      "text": "Suchergebnisse und Expertenfeedback.",
    },
    {
      "kind": "Comment",
      "text": "═══════════════════════════════════════",
    },
    {
      "kind": "Op.Wait",
      "mode": null,
      "name": null,
      "on": [
        {
          "name": "analyse",
        },
      ],
      "timeout": null,
    },
    {
      "kind": "Comment",
      "text": "═══════════════════════════════════════",
    },
    {
      "kind": "Comment",
      "text": "5. Antwort übermitteln.",
    },
    {
      "kind": "Comment",
      "text": "═══════════════════════════════════════",
    },
    {
      "await": null,
      "body": {
        "parts": [
          {
            "type": "text",
            "value": "
  ",
          },
          {
            "name": "analyse",
            "path": [
              "antwort",
            ],
            "type": "ref",
          },
          {
            "type": "text",
            "value": "
  ",
          },
        ],
        "type": "template",
      },
      "for": [
        "autor",
      ],
      "kind": "Op.Send",
      "name": null,
      "replyTo": null,
      "timeout": null,
      "to": {
        "segments": [
          {
            "kind": "literal",
            "value": "ergebnisse",
          },
          {
            "kind": "dynamic",
            "name": "fall_id",
            "path": [],
          },
        ],
      },
    },
    {
      "kind": "Op.Exit",
    },
  ],
}
`;

