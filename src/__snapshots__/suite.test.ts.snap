          "description": "путь к файлу",
          "name": "file_path",
          "typeArgs": [],
          "typeId": "Typ.Text",
        },
        {
          "depth": 1,
          "description": "назначение изменения",
          "name": "purpose",
          "typeArgs": [],
          "typeId": "Typ.Text",
        },
        {
          "depth": 1,
          "description": "тип изменения",
          "name": "change_type",
          "typeArgs": [
            "create",
            "modify",
            "delete",
          ],
          "typeId": "Typ.Choice",
        },
      ],
      "using": [],
      "via": null,
    },
    {
      "kind": "Op.Wait",
      "mode": null,
      "name": null,
      "on": [
        {
          "name": "plan",
        },
      ],
      "timeout": null,
    },
    {
      "kind": "Comment",
      "text": "═══════════════════════════════════════",
    },
    {
      "kind": "Comment",
      "text": "Реализация каждого шага плана",
    },
    {
      "kind": "Comment",
      "text": "═══════════════════════════════════════",
    },
    {
      "body": [
        {
          "body": [
            {
              "body": {
                "name": "worker_create_role",
                "path": [],
                "type": "ref",
              },
              "kind": "Op.Define",
              "name": "current_role",
            },
          ],
          "condition": "$task.change_type == "create"",
          "kind": "Op.If",
        },
        {
          "body": [
            {
              "body": {
                "name": "worker_modify_role",
                "path": [],
                "type": "ref",
              },
              "kind": "Op.Define",
              "name": "current_role",
            },
          ],
          "condition": "$task.change_type == "modify"",
          "kind": "Op.If",
        },
        {
          "body": [
            {
              "body": {
                "name": "worker_delete_role",
                "path": [],
                "type": "ref",
              },
              "kind": "Op.Define",
              "name": "current_role",
            },
          ],
          "condition": "$task.change_type == "delete"",
          "kind": "Op.If",
        },
        {
          "as": [
            {
              "name": "current_role",
              "path": [],
              "type": "ref",
            },
          ],
          "body": null,
          "context": {
            "parts": [
              {
                "type": "text",
                "value": "
    Общая задача: ",
              },
              {
                "name": "message",
                "path": [],
                "type": "ref",
              },
              {
                "type": "text",
                "value": "
    План: ",
              },
              {
                "name": "plan",
                "path": [],
                "type": "ref",
              },
              {
                "type": "text",
                "value": "
    ",
              },
            ],
            "type": "template",
          },
          "goal": {
            "parts": [
              {
                "type": "text",
                "value": "
    Реализуй изменение для файла.
    ",
              },
            ],
            "type": "template",
          },
          "input": {
            "parts": [
              {
                "type": "text",
                "value": "
    Файл: ",
              },
              {
                "name": "task",
                "path": [
                  "file_path",
                ],
                "type": "ref",
              },
              {
                "type": "text",
                "value": "
    Назначение: ",
              },
              {
                "name": "task",
                "path": [
                  "purpose",
                ],
                "type": "ref",
              },
              {
                "type": "text",
                "value": "
    Тип изменения: ",
              },
              {
                "name": "task",
                "path": [
                  "change_type",
                ],
                "type": "ref",
              },
              {
                "type": "text",
                "value": "
    ",
              },
            ],
            "type": "template",
          },
          "kind": "Op.Think",
          "name": "implementation",
          "result": [
            {
              "depth": 0,
              "description": "что было сделано и почему",
              "name": "explanation",
              "typeArgs": [],
              "typeId": "Typ.Text",
            },
            {
              "depth": 0,
              "description": "реализованный код",
              "name": "code",
              "typeArgs": [],
              "typeId": "Typ.Text",
            },
          ],
          "using": [],
          "via": null,
        },
        {
          "kind": "Op.Wait",
          "mode": null,
          "name": null,
          "on": [
            {
              "name": "implementation",
            },
          ],
          "timeout": null,
        },
      ],
      "element": {
        "name": "task",
        "path": [],
        "type": "ref",
      },
      "from": {
        "name": "plan",
        "path": [
          "files",
        ],
        "type": "ref",
      },
      "kind": "Op.Each",
    },
    {
      "kind": "Comment",
      "text": "═══════════════════════════════════════",
    },
    {
      "kind": "Comment",
      "text": "Отправка результата",
    },
    {
      "kind": "Comment",
      "text": "═══════════════════════════════════════",
    },
    {
      "await": null,
      "body": {
        "parts": [
          {
            "type": "text",
            "value": "
  План: ",
          },
          {
            "name": "plan",
            "path": [],
            "type": "ref",
          },
          {
            "type": "text",
            "value": "
  Реализация завершена.
  ",
          },
        ],
        "type": "template",
      },
      "for": [
        "инициатор",
      ],
      "kind": "Op.Send",
      "name": null,
      "replyTo": null,
      "timeout": null,
      "to": null,
